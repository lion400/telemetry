# ═══════════════════════════════════════════════════════════════
# SolarTrack — Configuración Backend
# EMOV Paradas Seguras · Sistema de Telemetría
# ═══════════════════════════════════════════════════════════════

# ── Servidor ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Seguridad — CAMBIAR EN PRODUCCIÓN ────────────────────────
JWT_SECRET=solartrack-jwt-change-in-prod-2024
SESSION_SECRET=solartrack-session-change-in-prod-2024

# ── Base de datos ────────────────────────────────────────────
DB_PATH=./solartrack.db

# ── Frontend (CORS) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=https://telemetria.emov.gob.ec

# ══════════════════════════════════════════════════════════════
# Plan SIM M2M — GV310LAU (especificación proveedor)
# ══════════════════════════════════════════════════════════════
# Tamaño mensaje:    150 bytes por reporte GPS/telemetría
# Modo pasivo:       2,880 reportes/mes → 1 cada 15 minutos
# Modo intensivo:    ~2,700 reportes/mes → ~1 cada 15-30 seg
# Keep-alive TCP:    ~1 MB/mes (mantenimiento sesión IP)
# Consumo estimado:  2.5 MB/mes por chip
# Plan contratado:   10 MB/mes (margen picos + OTA firmware)
# Comunicación:      Bidireccional · APN Pasivo · Servidor Nube
# ══════════════════════════════════════════════════════════════

# Intervalo simulador (segundos)
# Demo: 15s para ver cambios · Producción: 900s = 15 min real
SIM_INTERVAL=15

# Modo intensivo automático al detectar eventos
# GV310 cambia a 15s durante 5 minutos cuando hay alarma
INTENSIVE_INTERVAL=15
INTENSIVE_DURATION=300

# ── Email (configurar al tener servidor SMTP) ────────────────
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=alertas@emov.gob.ec
# EMAIL_PASS=app-password-aqui

# ── WhatsApp vía Twilio ───────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── APN M2M (para AT commands en GV310) ──────────────────────
# APN=m2m.tuproveedor.ec
# APN_USER=
# APN_PASS=
